{
  "name": "befu",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && lefthook install || true",
    "hooks:install": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && lefthook install || true",
    "create:app": "bun run --cwd tools/create-befu-app create-befu-app",
    "doctor": "bash scripts/doctor.sh",
    "bootstrap": "bash scripts/bootstrap.sh",
    "dev": "bun run --cwd apps/web dev",
    "dev:mobile": "bash scripts/dev/mobile.sh",
    "build": "bun run --cwd apps/web build",
    "check": "bun run --cwd apps/web tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:bridge": "bun run --cwd packages/bridge test",
    "test:rust": "cargo test --manifest-path crates/core/Cargo.toml",
    "rust:fmt": "cargo fmt --all",
    "rust:fmt:check": "cargo fmt --all --check",
    "rust:clippy": "cargo clippy --all-targets --all-features -- -D warnings",
    "quality": "bun run lint && bun run format:check && bun run check && bun run test:bridge && bun run rust:fmt:check && bun run rust:clippy && bun run test:rust && bun run build",
    "android:dev": "bun run --cwd apps/web dev --host 0.0.0.0 --port 5173",
    "android:setup": "bash scripts/android/setup.sh",
    "android:up": "bash scripts/android/dev.sh",
    "android:down": "bash scripts/android/stop.sh",
    "android:status": "bash scripts/android/doctor.sh",
    "android:assemble:debug": "./android/gradlew -p android :app:assembleDebug",
    "android:assemble:release": "./android/gradlew -p android :app:assembleRelease",
    "android:install:debug": "./android/gradlew -p android :app:installDebug",
    "android:emulator:start": "emulator -avd Pixel_7",
    "android:app:start": "adb shell am start -n dev.befu.app/.MainActivity",
    "android:app:restart": "adb shell am force-stop dev.befu.app && adb shell am start -n dev.befu.app/.MainActivity",
    "android:devices": "adb devices -l",
    "android:logs": "adb logcat -d | rg -i \"BefuMainActivity|WebView|ERR_\"",
    "android:doctor": "cargo ndk --version && rustup target list --installed | rg \"android\" && adb devices -l",
    "android:smoke": "bash scripts/android/smoke.sh",
    "ios:project": "xcodegen generate --spec ios/project.yml",
    "ios:assets": "bash scripts/ios/prepare-assets.sh",
    "ios:rust": "bash scripts/ios/prepare-rust.sh",
    "ios:prepare": "bun run ios:assets && bun run ios:rust && bun run ios:project",
    "ios:sim:list": "xcrun simctl list devices available",
    "ios:build:sim": "xcodebuild -project ios/BefuIOS.xcodeproj -scheme Befu -destination \"generic/platform=iOS Simulator\" -derivedDataPath ios/build build",
    "ios:sim:install": "xcrun simctl install booted ios/build/Build/Products/Debug-iphonesimulator/Befu.app",
    "ios:sim:launch": "xcrun simctl launch booted dev.befu.ios",
    "ios:smoke": "bash scripts/ios/smoke.sh",
    "ios:up": "bun run ios:prepare && bun run ios:build:sim && bun run ios:sim:install && bun run ios:sim:launch",
    "ios:dev": "bun run dev",
    "watch:rust": "bash scripts/dev/watch-rust.sh",
    "a:hot": "bun run watch:rust android",
    "i:hot": "bun run watch:rust ios",
    "a:up": "bun run android:up",
    "a:down": "bun run android:down",
    "a:logs": "bun run android:logs",
    "a:restart": "bun run android:app:restart",
    "a:smoke": "bun run android:smoke",
    "i:list": "bun run ios:sim:list",
    "i:build": "bun run ios:build:sim",
    "i:install": "bun run ios:sim:install",
    "i:launch": "bun run ios:sim:launch",
    "i:up": "bun run ios:up",
    "i:dev": "bun run ios:dev",
    "i:smoke": "bun run ios:smoke"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "bun-types": "^1.3.11",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.4.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  }
}
